<Window x:Class="Libraries.ErrorModelLib.WarningWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Libraries.ErrorModelLib"
             mc:Ignorable="d" 
             d:DesignHeight="450"
             d:DesignWidth="800"
             Title="Предупреждение"
             WindowStartupLocation="CenterScreen"
             ResizeMode="NoResize">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TextMessage"
                   TextWrapping="Wrap"
                   FontSize="14"
                   Margin="0,0,0,10"/>

        <Image x:Name="DialogImage"
               Grid.Row="1"
               Stretch="Uniform"
               Margin="0,10"/>

        <Button Grid.Row="2"
                Content="OK"
                Width="120"
                Height="30"
                HorizontalAlignment="Center"
                Click="Ok_Click"/>

    </Grid>
</Window>
